# ── Video Generation Backend ───────────────────────────────────────────────────
#
# Options:
#   replicate_svd      → Stable Video Diffusion via Replicate (default, no GPU needed)
#   replicate_minimax  → Minimax Video-01 via Replicate (full text-prompt support)
#   huggingface_local  → Local SVD XT inference (requires ~16 GB VRAM + diffusers)
#
VIDEO_BACKEND=replicate_svd

# ── Replicate API Token ────────────────────────────────────────────────────────
# Required for replicate_svd and replicate_minimax backends.
# Get your free token at: https://replicate.com/account/api-tokens
#
REPLICATE_API_TOKEN=your_replicate_token_here

# ── HuggingFace Token (optional) ──────────────────────────────────────────────
# Only needed if you use the huggingface_local backend AND access gated models.
# Get your token at: https://huggingface.co/settings/tokens
#
HF_TOKEN=your_hf_token_here
